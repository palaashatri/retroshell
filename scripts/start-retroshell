#!/usr/bin/env bash
# start-retroshell — XDG Wayland session entry for RetroShell.
#
# Prefer retro-compositor when available. If it is missing from PATH, forced
# off, or dies early (common under nested X without DRI3), fall back to labwc
# with an honest message. Then exec retro-shell as the session client.
#
# Overrides:
#   RETROSHELL_COMPOSITOR=labwc|retro-compositor
#   RETROSHELL_FORCE_LABWC=1          — same as COMPOSITOR=labwc
#   RETROSHELL_COMPOSITOR_WAIT_SECS   — how long to wait for compositor (default 3)
#   WLR_BACKENDS / WLR_RENDERER_ALLOW_SOFTWARE — passed through to labwc if set
set -euo pipefail

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-RetroShell}"
export DESKTOP_SESSION="${DESKTOP_SESSION:-retroshell}"

if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
  export XDG_RUNTIME_DIR="/run/user/$(id -u)"
fi
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR" 2>/dev/null || true

WAIT_SECS="${RETROSHELL_COMPOSITOR_WAIT_SECS:-3}"
COMPOSITOR_LOG="${XDG_RUNTIME_DIR}/retro-compositor.log"
COMPOSITOR_PID=""

die() {
  echo "start-retroshell: $*" >&2
  exit 1
}

resolve_bin() {
  local name="$1"
  if command -v "$name" >/dev/null 2>&1; then
    command -v "$name"
    return 0
  fi
  # Dev trees: next to this script → repo target/{release,debug}
  local here
  here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local candidate
  for candidate in \
    "$here/../target/release/$name" \
    "$here/../target/debug/$name" \
    "$HOME/.local/bin/$name" \
    "/usr/local/bin/$name" \
    "/usr/bin/$name"
  do
    if [ -x "$candidate" ]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

pick_wayland_display() {
  # Prefer socket name published by retro-compositor (Docker entrypoint path),
  # then XDG_RUNTIME_DIR, then wayland-0.
  local socket=""
  if [ -f /tmp/runtime-root/wayland-display ]; then
    socket="$(tr -d '[:space:]' </tmp/runtime-root/wayland-display || true)"
  fi
  if [ -z "$socket" ] && [ -f "$XDG_RUNTIME_DIR/wayland-display" ]; then
    socket="$(tr -d '[:space:]' <"$XDG_RUNTIME_DIR/wayland-display" || true)"
  fi
  if [ -z "$socket" ]; then
    # Newest wayland-* socket that is not a lock file
    local f
    for f in "$XDG_RUNTIME_DIR"/wayland-*; do
      [ -S "$f" ] || continue
      socket="$(basename "$f")"
    done
  fi
  if [ -z "$socket" ]; then
    socket="wayland-0"
  fi
  echo "$socket"
}

start_labwc() {
  local labwc_bin
  labwc_bin="$(resolve_bin labwc)" || die "labwc not found on PATH (needed for fallback or RETROSHELL_COMPOSITOR=labwc)"

  echo "start-retroshell: launching labwc ($labwc_bin)"
  # Nested under X11 (Docker/Xvfb/desktop X): use x11 backend if caller did not set WLR_BACKENDS.
  # Bare-metal Wayland/DRM sessions leave WLR_BACKENDS unset so labwc uses its default.
  if [ -n "${WLR_BACKENDS:-}" ]; then
    echo "start-retroshell: using existing WLR_BACKENDS=$WLR_BACKENDS"
    "$labwc_bin" &
  elif [ -n "${DISPLAY:-}" ]; then
    echo "start-retroshell: DISPLAY=$DISPLAY set; starting labwc with WLR_BACKENDS=x11 (nested / no native DRM seat)"
    echo "start-retroshell: note — software rendering may be used; this is the honest labwc fallback path"
    WLR_BACKENDS=x11 WLR_RENDERER_ALLOW_SOFTWARE="${WLR_RENDERER_ALLOW_SOFTWARE:-1}" "$labwc_bin" &
  else
    echo "start-retroshell: starting labwc on default backend (expect DRM/KMS session)"
    "$labwc_bin" &
  fi
  COMPOSITOR_PID=$!
  sleep 2
  if ! kill -0 "$COMPOSITOR_PID" 2>/dev/null; then
    die "labwc exited immediately (pid $COMPOSITOR_PID)"
  fi
  export WAYLAND_DISPLAY
  WAYLAND_DISPLAY="$(pick_wayland_display)"
  echo "start-retroshell: labwc running (pid $COMPOSITOR_PID), WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
}

start_retro_compositor() {
  local comp_bin
  comp_bin="$(resolve_bin retro-compositor)" || {
    echo "start-retroshell: retro-compositor not on PATH"
    return 1
  }

  : >"$COMPOSITOR_LOG"
  echo "start-retroshell: launching retro-compositor ($comp_bin)"
  echo "start-retroshell: log → $COMPOSITOR_LOG"
  "$comp_bin" >>"$COMPOSITOR_LOG" 2>&1 &
  COMPOSITOR_PID=$!

  local i
  for i in $(seq 1 "$WAIT_SECS"); do
    if ! kill -0 "$COMPOSITOR_PID" 2>/dev/null; then
      echo "start-retroshell: retro-compositor died during startup wait (${i}s)"
      echo "start-retroshell: common cause under nested X / Docker-on-mac: missing DRI3 / GPU accel"
      echo "start-retroshell: --- retro-compositor log (tail) ---"
      tail -40 "$COMPOSITOR_LOG" 2>/dev/null || true
      COMPOSITOR_PID=""
      return 1
    fi
    sleep 1
  done

  if ! kill -0 "$COMPOSITOR_PID" 2>/dev/null; then
    echo "start-retroshell: retro-compositor not running after ${WAIT_SECS}s"
    tail -40 "$COMPOSITOR_LOG" 2>/dev/null || true
    COMPOSITOR_PID=""
    return 1
  fi

  # Allow socket file to appear
  local _try
  for _try in $(seq 1 20); do
    if [ -f /tmp/runtime-root/wayland-display ] || [ -f "$XDG_RUNTIME_DIR/wayland-display" ]; then
      break
    fi
    # Also break early if a wayland socket already exists
    if compgen -G "$XDG_RUNTIME_DIR/wayland-*" >/dev/null 2>&1; then
      break
    fi
    sleep 0.25
  done

  export WAYLAND_DISPLAY
  WAYLAND_DISPLAY="$(pick_wayland_display)"
  echo "start-retroshell: retro-compositor running (pid $COMPOSITOR_PID), WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
  return 0
}

# --- choose compositor -------------------------------------------------------

choice="${RETROSHELL_COMPOSITOR:-}"
if [ -n "${RETROSHELL_FORCE_LABWC:-}" ]; then
  echo "start-retroshell: RETROSHELL_FORCE_LABWC is set → labwc"
  choice="labwc"
fi

case "${choice}" in
  labwc)
    start_labwc
    ;;
  retro-compositor)
    if ! start_retro_compositor; then
      die "RETROSHELL_COMPOSITOR=retro-compositor requested but compositor failed to start"
    fi
    ;;
  "")
    # Default: prefer retro-compositor when present and not forced off
    if resolve_bin retro-compositor >/dev/null 2>&1; then
      if ! start_retro_compositor; then
        echo "start-retroshell: falling back to labwc (DRI3/GPU path unavailable or compositor crashed)"
        start_labwc
      fi
    else
      echo "start-retroshell: retro-compositor not found; using labwc"
      start_labwc
    fi
    ;;
  *)
    die "unknown RETROSHELL_COMPOSITOR='$choice' (use labwc or retro-compositor)"
    ;;
esac

SHELL_BIN="$(resolve_bin retro-shell)" || die "retro-shell not found on PATH or in target/{release,debug}"
echo "start-retroshell: exec retro-shell ($SHELL_BIN) on WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset}"
# Unset DISPLAY for pure Wayland clients when a Wayland socket is live, unless caller keeps it.
# Nested labwc under X still needs DISPLAY for the compositor process (already running).
if [ -n "${WAYLAND_DISPLAY:-}" ] && [ "${RETROSHELL_KEEP_DISPLAY:-}" != "1" ]; then
  exec env -u DISPLAY "$SHELL_BIN" "$@"
else
  exec "$SHELL_BIN" "$@"
fi
